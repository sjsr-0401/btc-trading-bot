<Window x:Class="BtcTradingBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BtcTradingBot.ViewModels"
        xmlns:views="clr-namespace:BtcTradingBot.Views"
        Title="BTC Trading Bot" Height="800" Width="1400"
        MinHeight="600" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="False"
        Background="{DynamicResource BgDarkBrush}"
        ResizeMode="CanResizeWithGrip">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6"
                      GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════ 커스텀 타이틀바 ═══════ -->
        <Border Grid.Row="0" Background="{DynamicResource BgCardBrush}"
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="BTC Trading Bot" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="─" Click="Minimize_Click"
                            Width="46" Height="40" FontSize="12" Cursor="Hand"
                            Foreground="{DynamicResource TextSecondaryBrush}" Background="Transparent"
                            BorderThickness="0"/>
                    <Button x:Name="MaxBtn" Content="☐" Click="Maximize_Click"
                            Width="46" Height="40" FontSize="13" Cursor="Hand"
                            Foreground="{DynamicResource TextSecondaryBrush}" Background="Transparent"
                            BorderThickness="0"/>
                    <Button Content="✕" Click="Close_Click"
                            Width="46" Height="40" FontSize="13" Cursor="Hand"
                            Foreground="{DynamicResource TextSecondaryBrush}" Background="Transparent"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Classic 모드 ═══ -->
        <Grid Grid.Row="1" Visibility="{Binding IsClassicMode, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="160"/>
            </Grid.RowDefinitions>

        <!-- ═══════ 헤더 바 ═══════ -->
        <Border Grid.Row="0" Background="{DynamicResource BgCardBrush}"
                Padding="20,10" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding SelectedSymbolDisplay}" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" Text="{Binding ChartVm.CurrentPrice}" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="16,0,0,0"/>

                <TextBlock Grid.Column="2" Text="{Binding ChartVm.PriceChange}" FontSize="14"
                           Foreground="{Binding ChartVm.PriceChangeColor, Converter={StaticResource StringToBrush}}"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>

                <!-- 네비게이션 탭 -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Border x:Name="NavScanner" CornerRadius="6,0,0,6" Padding="14,5" Cursor="Hand"
                            MouseLeftButtonUp="NavScanner_Click" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsScannerPage}" Value="True">
                                        <Setter Property="Background" Value="#333B82F6"/>
                                        <Setter Property="BorderBrush" Value="#FF3B82F6"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="스캐너" FontSize="12" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScannerPage}" Value="True">
                                            <Setter Property="Foreground" Value="#FF3B82F6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <Border x:Name="NavTrading" CornerRadius="0,6,6,0" Padding="14,5" Cursor="Hand"
                            MouseLeftButtonUp="NavTrading_Click" BorderThickness="1,1,1,1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTradingPage}" Value="True">
                                        <Setter Property="Background" Value="#333B82F6"/>
                                        <Setter Property="BorderBrush" Value="#FF3B82F6"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="트레이딩" FontSize="12" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTradingPage}" Value="True">
                                            <Setter Property="Foreground" Value="#FF3B82F6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Column="4" Text="{Binding PositionText}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{Binding PositionColor, Converter={StaticResource StringToBrush}}"
                           VerticalAlignment="Center"/>

                <!-- 테스트 모드 토글 -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Border x:Name="TestToggleBorder" CornerRadius="12" Padding="8,4" Cursor="Hand"
                            MouseLeftButtonUp="TestToggle_Click" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTestMode}" Value="True">
                                        <Setter Property="Background" Value="#33F59E0B"/>
                                        <Setter Property="BorderBrush" Value="#FFF59E0B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FF888888"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTestMode}" Value="True">
                                                <Setter Property="Fill" Value="#FFF59E0B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="실전"/>
                                        <Setter Property="Foreground" Value="#FF888888"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTestMode}" Value="True">
                                                <Setter Property="Text" Value="테스트"/>
                                                <Setter Property="Foreground" Value="#FFF59E0B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <!-- 테스트 모드 설정 버튼 -->
                    <Button Content="⚙" Command="{Binding OpenTestSettingsCommand}"
                            Width="28" Height="28" FontSize="14" Cursor="Hand" Margin="4,0,0,0"
                            Foreground="#FFF59E0B" Background="Transparent" BorderThickness="0"
                            ToolTip="가상 자금 설정"
                            Visibility="{Binding IsTestMode, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="{Binding Balance}" FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <Button Content="↻" Command="{Binding RefreshBalanceCommand}"
                            Width="28" Height="28" FontSize="14" Cursor="Hand" Margin="6,0,0,0"
                            Foreground="{DynamicResource TextSecondaryBrush}" Background="Transparent"
                            BorderThickness="0" ToolTip="잔고 새로고침"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>

                <Border Grid.Column="8" Background="{DynamicResource BgInputBrush}"
                        CornerRadius="12" Padding="12,4" Margin="16,0,0,0">
                    <TextBlock Text="{Binding StatusText}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════ 테스트 모드 배너 ═══════ -->
        <Border Grid.Row="1" Background="#FFF59E0B" Padding="8,5"
                Visibility="{Binding IsTestMode, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="테스트 모드 — 가상 자금으로 운영 중" FontSize="12" FontWeight="SemiBold"
                       Foreground="#FF1A1A1A" HorizontalAlignment="Center"/>
        </Border>

        <!-- ═══════ 메인 영역 ═══════ -->
        <Grid Grid.Row="2">
            <!-- 스캐너 페이지 -->
            <Border Background="{DynamicResource BgCardBrush}" Margin="12,12,12,12" CornerRadius="10"
                    Visibility="{Binding IsScannerPage, Converter={StaticResource BoolToVisibility}}">
                <views:ScannerControl DataContext="{Binding ScannerVm}"/>
            </Border>

            <!-- 트레이딩 페이지 -->
            <Grid Visibility="{Binding IsTradingPage, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- ══ 왼쪽: 거래 내역 ══ -->
            <Border Grid.Column="0" Margin="12,12,6,12" Background="{DynamicResource BgCardBrush}"
                    CornerRadius="10" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="거래 내역" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                    <!-- 포지션 정보 -->
                    <Border Grid.Row="1" Background="{DynamicResource BgInputBrush}"
                            CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="포지션" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding PositionText}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{Binding PositionColor, Converter={StaticResource StringToBrush}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="미실현" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding UnrealizedPnlText}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{Binding UnrealizedPnlColor, Converter={StaticResource StringToBrush}}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="SL / TP" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding SlTpText}" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="보유시간" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" ToolTip="포지션 진입 후 경과 시간"/>
                                <TextBlock Grid.Column="1" Text="{Binding HoldDuration}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="총 PnL" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{Binding TotalPnl, Converter={StaticResource PnlToColor}}">
                                    <Run Text="$"/><Run Text="{Binding TotalPnl, StringFormat=F2, Mode=OneWay}"/>
                                </TextBlock>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="승률" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding WinRate}" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="수익팩터 (PF)" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" ToolTip="Profit Factor = 총이익 / 총손실. 1.0 이상이면 수익 전략."/>
                                <TextBlock Grid.Column="1" Text="{Binding ProfitFactor}" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="MDD" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" ToolTip="Maximum Drawdown — 최고점 대비 최대 하락 비율"/>
                                <TextBlock Grid.Column="1" Text="{Binding MaxDrawdown}" FontSize="12"
                                           Foreground="#EF4444"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="평균 W/L" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" ToolTip="평균 수익(Win) / 평균 손실(Loss) — USDT 기준"/>
                                <TextBlock Grid.Column="1" Text="{Binding AvgWinLoss}" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="오늘 (USDT)" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" ToolTip="오늘 거래 횟수 / 일일 손익 (USDT)"/>
                                <TextBlock Grid.Column="1" Text="{Binding DailyInfo}" FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 거래 목록 -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding TradeRecords}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter Margin="0,0,0,6"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgInputBrush}"
                                        CornerRadius="6" Padding="10,8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding SymbolShort}" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Side}" FontWeight="Bold" FontSize="12" Margin="6,0,0,0"
                                                       Foreground="{Binding SideColor, Converter={StaticResource StringToBrush}}"/>
                                            <TextBlock Text="{Binding TimeText}" FontSize="11" Margin="8,0,0,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding PnlText}" FontWeight="Bold" FontSize="12"
                                                       Foreground="{Binding PnlColor, Converter={StaticResource StringToBrush}}"/>
                                            <TextBlock Text="{Binding PnlPercentText}" FontSize="10" Margin="4,2,0,0"
                                                       Foreground="{Binding PnlColor, Converter={StaticResource StringToBrush}}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,2,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                                <Run Text="{Binding EntryPrice, StringFormat=N2, Mode=OneWay}"/>
                                                <Run Text="→"/>
                                                <Run Text="{Binding ExitPrice, StringFormat=N2, Mode=OneWay}"/>
                                            </TextBlock>
                                            <Border Grid.Column="1" CornerRadius="3" Padding="5,1" VerticalAlignment="Center"
                                                    Background="{Binding CloseReasonColor, Converter={StaticResource StringToBrush}}" Opacity="0.85">
                                                <TextBlock Text="{Binding CloseReason}" FontSize="9" FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" FontSize="10" Margin="0,2,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}">
                                            <Run Text="잔고:"/>
                                            <Run Text="{Binding BalanceText, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 거래 없을 때 -->
                    <TextBlock Grid.Row="2" Text="아직 거래 내역이 없습니다"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,30,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TradeRecords.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- ══ 중앙: 차트 ══ -->
            <Border Grid.Column="1" Margin="6,12,6,12" Background="{DynamicResource BgCardBrush}"
                    CornerRadius="10" Padding="16">
                <Border.CacheMode>
                    <BitmapCache/>
                </Border.CacheMode>
                <views:ChartControl DataContext="{Binding ChartVm}"/>
            </Border>

            <!-- ══ 오른쪽: 설정 ══ -->
            <ScrollViewer x:Name="SettingsScroll" Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="6,12,12,12"
                          CanContentScroll="False" PreviewMouseWheel="SettingsScroll_PreviewMouseWheel">
                <StackPanel>
                    <!-- 엔진 선택 + 설명 + 실시간 분석 -->
                    <Border Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                        <StackPanel>
                            <!-- 엔진 선택 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="엔진" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox Grid.Column="1" FontSize="12"
                                          SelectedValue="{Binding SelectedEngine}" SelectedValuePath="Tag"
                                          IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBool}}">
                                    <ComboBoxItem Content="KYJ v0.3" Tag="KYJ" IsSelected="True"/>
                                </ComboBox>
                            </Grid>

                            <!-- 엔진 설명: KYJ -->
                            <Border Background="{DynamicResource BgInputBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="KYJ v0.3 — EMA 크로스 + 복합지표" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" LineHeight="16">
                                        <Run>7개 지표(EMA배열, RSI, MACD, ADX, 거래량, 캔들, 추세)의</Run>
                                        <Run FontWeight="SemiBold">복합 점수</Run>
                                        <Run>로 매매 방향 결정.</Run>
                                        <Run>ATR 기반 SL/TP + 트레일링 스탑으로 리스크 관리.</Run>
                                        <LineBreak/>
                                        <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">진입 기준:</Run>
                                        <Run>총점 45점 이상 + 3봉 추적 + 4회 확인 후 진입</Run>
                                        <LineBreak/>
                                        <Run FontWeight="SemiBold" Foreground="#F59E0B">적합 시장:</Run>
                                        <Run>추세장 (ADX 높을 때). 횡보장에서는 신호 적음.</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- 실시간 엔진 상태 -->
                            <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Background" Value="#1A3B82F6"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <!-- 엔진 상태 헤더 -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#888888"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Fill" Value="#22C55E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Grid.Column="1" Text="{Binding EngineState}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Grid>

                                    <!-- 마지막 분석 결과 (봇 실행 후 분석 있을 때만) -->
                                    <StackPanel Visibility="{Binding HasAnalysis, Converter={StaticResource BoolToVisibility}}">
                                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,2,0,6"/>

                                        <!-- 방향 + 점수 (공통) -->
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="판단" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding LastDirection}" FontSize="12" FontWeight="Bold"
                                                       Foreground="{Binding LastDirectionColor, Converter={StaticResource StringToBrush}}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding LastScore, Mode=OneWay}"/><Run Text="점"/>
                                            </TextBlock>
                                        </Grid>

                                        <!-- ═══ KYJ 분석 패널 ═══ -->
                                        <StackPanel>
                                            <TextBlock Text="{Binding CrossInfo}" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/><ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="RSI" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding AnalysisRsi}" FontSize="10"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/><ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="MACD" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding AnalysisMacd}" FontSize="10"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/><ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="ADX" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding AnalysisAdx}" FontSize="10"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/><ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="거래량" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding AnalysisVolume}" FontSize="10"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/><ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="캔들" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding AnalysisCandle}" FontSize="10"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/><ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="1H추세" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding AnalysisTrend1H}" FontSize="10"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/><ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="4H추세" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding AnalysisTrend4H}" FontSize="10"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Grid>
                                        </StackPanel>

                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 봇 제어 버튼 (항상 활성) -->
                    <Border Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,10">
                        <StackPanel>
                            <Button Content="{Binding IsRunning, Converter={StaticResource BoolToRunningText}}"
                                    Command="{Binding ToggleBotCommand}"
                                    Style="{StaticResource SuccessButton}" Margin="0,0,0,6"/>
                            <Button Content="수동 청산" Command="{Binding ManualCloseCommand}"
                                    Style="{StaticResource DangerButton}"
                                    IsEnabled="{Binding HasOpenPosition}"
                                    ToolTip="현재 포지션을 시장가로 즉시 청산하고 SL/TP 주문을 취소합니다."/>
                        </StackPanel>
                    </Border>

                    <!-- 거래 설정 -->
                    <Border Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,10"
                            IsEnabled="{Binding CanEditSettings}">
                        <StackPanel>
                            <TextBlock Text="거래 설정" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,14"/>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/><ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="레버리지"/>
                                <TextBlock Grid.Column="1" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center">
                                    <Run Text="{Binding Leverage, Mode=OneWay}"/><Run Text="x"/>
                                </TextBlock>
                            </Grid>
                            <Slider Value="{Binding Leverage}" Minimum="1" Maximum="20"
                                    TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,12"/>

                            <Label Content="거래 금액 (USDT)"/>
                            <TextBox Text="{Binding TradeUsdt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                            <UniformGrid Columns="5" Margin="0,0,0,12">
                                <Button Content="10%" Command="{Binding SetTradePercentCommand}" CommandParameter="10"
                                        FontSize="11" Height="26" Margin="0,0,2,0" Cursor="Hand"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Background="{DynamicResource BgInputBrush}" BorderThickness="1"
                                        BorderBrush="{DynamicResource BorderBrush}"/>
                                <Button Content="25%" Command="{Binding SetTradePercentCommand}" CommandParameter="25"
                                        FontSize="11" Height="26" Margin="1,0,1,0" Cursor="Hand"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Background="{DynamicResource BgInputBrush}" BorderThickness="1"
                                        BorderBrush="{DynamicResource BorderBrush}"/>
                                <Button Content="50%" Command="{Binding SetTradePercentCommand}" CommandParameter="50"
                                        FontSize="11" Height="26" Margin="1,0,1,0" Cursor="Hand"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Background="{DynamicResource BgInputBrush}" BorderThickness="1"
                                        BorderBrush="{DynamicResource BorderBrush}"/>
                                <Button Content="75%" Command="{Binding SetTradePercentCommand}" CommandParameter="75"
                                        FontSize="11" Height="26" Margin="1,0,1,0" Cursor="Hand"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Background="{DynamicResource BgInputBrush}" BorderThickness="1"
                                        BorderBrush="{DynamicResource BorderBrush}"/>
                                <Button Content="MAX" Command="{Binding SetTradePercentCommand}" CommandParameter="100"
                                        FontSize="11" Height="26" Margin="2,0,0,0" Cursor="Hand" FontWeight="SemiBold"
                                        Foreground="{StaticResource AccentBrush}"
                                        Background="{DynamicResource BgInputBrush}" BorderThickness="1"
                                        BorderBrush="{StaticResource AccentBrush}"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- 스캐너 설정 -->
                    <Border Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,10"
                            IsEnabled="{Binding CanEditSettings}">
                        <Expander Header="스캐너 설정" Foreground="{DynamicResource TextPrimaryBrush}"
                                  FontSize="14" FontWeight="SemiBold" IsExpanded="False">
                            <StackPanel Margin="0,12,0,0">
                                <Label Content="스캔 간격 (초)"/>
                                <TextBlock Text="코인 스캐너 자동 새로고침 주기 (30~300초)" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding ScanIntervalSec, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <Label Content="스캔 코인 수"/>
                                <TextBlock Text="상위 거래량 기준으로 스캔할 코인 개수 (5~20개)" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding ScanCoinCount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <CheckBox IsChecked="{Binding AutoSwitchEnabled}" Margin="0,4,0,2"
                                          Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12">
                                    <TextBlock Text="자동 코인 전환" FontWeight="SemiBold"/>
                                </CheckBox>
                                <TextBlock TextWrapping="Wrap" FontSize="10" Margin="20,0,0,4"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    스캔 결과에서 진입 점수 이상인 코인 발견 시 자동 전환 (5분 쿨다운)
                                </TextBlock>

                                <Label Content="진입 점수" Margin="0,6,0,0"/>
                                <TextBlock Text="자동 전환 기준 점수 (45~100)" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding AutoEntryScore, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <Button Content="설정 저장" Command="{Binding SaveConfigCommand}"
                                        Style="{StaticResource SecondaryButton}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <!-- 리스크 관리 -->
                    <Border Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,10"
                            IsEnabled="{Binding CanEditSettings}">
                        <Expander Header="리스크 관리" Foreground="{DynamicResource TextPrimaryBrush}"
                                  FontSize="14" FontWeight="SemiBold" IsExpanded="False">
                            <StackPanel Margin="0,12,0,0">
                                <Label Content="체크 간격 (초)"/>
                                <TextBlock Text="봇이 시장을 분석하는 주기 (초 단위)" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding CheckInterval, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <Label Content="일일 최대 거래 (횟수)"/>
                                <TextBlock Text="하루에 봇이 실행할 수 있는 최대 거래 횟수" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding MaxDailyTrades, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <Label Content="일일 최대 손실 (%)"/>
                                <TextBlock Text="하루 누적 손실이 이 비율을 넘으면 봇 자동 중지" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding MaxDailyLossPct, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <Label Content="연속 손실 허용 (회)"/>
                                <TextBlock Text="연속으로 이 횟수만큼 손실 나면 쿨다운 진입" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding MaxConsecLosses, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <Label Content="쿨다운 시간 (분)"/>
                                <TextBlock Text="연속 손실 후 봇이 거래를 쉬는 시간" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding CooldownMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <Label Content="Discord Webhook URL (선택)"/>
                                <TextBlock Text="거래 알림을 디스코드 채널로 받을 웹훅 주소" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding DiscordWebhook, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                                <Button Content="설정 저장" Command="{Binding SaveConfigCommand}"
                                        Style="{StaticResource SecondaryButton}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <!-- 입금 가이드 -->
                    <Border Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="16">
                        <Expander Header="자금 관리 안내" Foreground="{DynamicResource TextPrimaryBrush}"
                                  FontSize="14" FontWeight="SemiBold" IsExpanded="False">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}">이 앱에서 직접 입금은 불가능합니다.</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run FontWeight="SemiBold">1.</Run><Run> 바이낸스 앱/웹에서 USDT를 입금하세요</Run>
                                    <LineBreak/><Run>   (은행이체, 카드, P2P, 코인전송)</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run FontWeight="SemiBold">2.</Run><Run> 현물 → 선물(USDⓈ-M) 지갑으로 이체</Run>
                                    <LineBreak/><Run>   바이낸스:</Run>
                                    <Run FontWeight="Bold" Foreground="#FFFBBF24"> Wallet </Run>
                                    <Run>→</Run>
                                    <Run FontWeight="Bold" Foreground="#FFFBBF24"> Transfer </Run>
                                    <LineBreak/><Run>   From: Spot → To: USDⓈ-M Futures</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run FontWeight="SemiBold">3.</Run><Run> 이 앱에서 잔고 확인 후 봇 시작</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run Foreground="{StaticResource AccentBrush}">최소 50 USDT 이상 권장</Run>
                                </TextBlock>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <!-- 수수료 · 선물 안내 -->
                    <Border Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="16" Margin="0,10,0,0">
                        <Expander Header="수수료 · 선물 거래 안내" Foreground="{DynamicResource TextPrimaryBrush}"
                                  FontSize="14" FontWeight="SemiBold" IsExpanded="False">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    <!-- 수수료 -->
                                    <Run FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}">거래 수수료</Run>
                                    <LineBreak/>
                                    <Run>바이낸스 선물 Taker 기준: </Run>
                                    <Run FontWeight="Bold" Foreground="#FFFBBF24">0.05%</Run>
                                    <Run> (매 거래마다)</Run>
                                    <LineBreak/>
                                    <Run>진입 1회 + 청산 1회 = 왕복 약 </Run>
                                    <Run FontWeight="Bold">0.10%</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">수수료 예시 (레버리지 4x 기준)</Run>
                                    <LineBreak/>
                                    <Run>  거래금액 $35 → 명목가치 $140 → 왕복 수수료 약 $0.14</Run>
                                    <LineBreak/>
                                    <Run>  거래금액 $100 → 명목가치 $400 → 왕복 수수료 약 $0.40</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run>실전: 바이낸스가 잔고에서 자동 차감</Run>
                                    <LineBreak/>
                                    <Run>테스트: 봇이 동일 수수료율로 가상 차감</Run>
                                    <LineBreak/><LineBreak/>
                                    <!-- 선물 거래 -->
                                    <Run FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}">바이낸스 USDⓈ-M 선물이란?</Run>
                                    <LineBreak/>
                                    <Run>USDT를 담보로 비트코인 가격 방향에 베팅하는 파생상품</Run>
                                    <LineBreak/>
                                    <Run>실제 비트코인을 사고파는 것이 아닙니다</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">필요한 것</Run>
                                    <LineBreak/>
                                    <Run>  </Run><Run FontWeight="Bold" Foreground="#FF22C55E">USDT만 있으면 됩니다</Run>
                                    <LineBreak/>
                                    <Run>  BTC를 보유할 필요 없음</Run>
                                    <LineBreak/>
                                    <Run>  현물 지갑이 아닌 </Run><Run FontWeight="Bold">선물(Futures) 지갑</Run><Run>에 USDT 필요</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">최소 거래 조건</Run>
                                    <LineBreak/>
                                    <Run>  BTCUSDT 최소 주문: 명목가치 </Run><Run FontWeight="Bold">5 USDT</Run>
                                    <LineBreak/>
                                    <Run>  레버리지 4x → 증거금 약 1.25 USDT부터 가능</Run>
                                    <LineBreak/>
                                    <Run>  권장: </Run><Run FontWeight="Bold" Foreground="{StaticResource AccentBrush}">50 USDT 이상</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">레버리지란?</Run>
                                    <LineBreak/>
                                    <Run>  적은 돈으로 큰 금액을 거래할 수 있는 배율</Run>
                                    <LineBreak/>
                                    <Run>  4x = $25로 $100만큼 거래 가능</Run>
                                    <LineBreak/>
                                    <Run>  수익도 4배, </Run><Run Foreground="#FFEF4444" FontWeight="Bold">손실도 4배</Run>
                                </TextBlock>
                            </StackPanel>
                        </Expander>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        </Grid>

        <!-- ═══════ 로그 패널 ═══════ -->
        <Border Grid.Row="3" Background="{DynamicResource BgCardBrush}"
                Margin="12,0,12,12" CornerRadius="10" Padding="16,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="시스템 로그" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         x:Name="LogListBox">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                       Foreground="{Binding Converter={StaticResource LogTextToColor}}"
                                       FontWeight="{Binding Converter={StaticResource LogTextToWeight}}"
                                       TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter Margin="0,1"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>
        </Grid>

        <!-- ═══ Multi 모드 ═══ -->
        <views:MultiTradingControl Grid.Row="1" x:Name="MultiContent"
            Visibility="{Binding DataContext.IsMultiMode,
                RelativeSource={RelativeSource AncestorType=Window},
                Converter={StaticResource BoolToVisibility}}"/>
    </Grid>
</Window>
