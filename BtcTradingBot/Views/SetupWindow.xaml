<Window x:Class="BtcTradingBot.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BtcTradingBot.ViewModels"
        Title="BTC Trading Bot"
        Height="700" Width="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.DataContext>
        <vm:SetupViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource BgDarkBrush}" CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══ 커스텀 타이틀바 ═══ -->
            <Border Grid.Row="0" Background="{StaticResource BgCardBrush}"
                    CornerRadius="12,12,0,0" Padding="16,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="BTC Trading Bot" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 뒤로가기 + 닫기 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BackBtn" Content="←" Click="Back_Click"
                                Visibility="{Binding CurrentStep, Converter={StaticResource StepToBackVisibility}}"
                                Width="32" Height="28" FontSize="15" Cursor="Hand"
                                Foreground="{StaticResource TextSecondaryBrush}" Background="Transparent"
                                BorderThickness="0" Margin="0,0,4,0"
                                ToolTip="이전 단계"/>
                        <Button Content="✕" Click="Close_Click"
                                Width="32" Height="28" FontSize="13" Cursor="Hand"
                                Foreground="{StaticResource TextSecondaryBrush}" Background="Transparent"
                                BorderThickness="0"
                                ToolTip="닫기"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ 컨텐츠 영역 (스크롤) ═══ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="36,24,36,32">

                    <!-- ═══ Step 0: Welcome ═══ -->
                    <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=0}">

                        <!-- 로고 영역 -->
                        <Border Width="72" Height="72" CornerRadius="16" Margin="0,24,0,16"
                                HorizontalAlignment="Center"
                                Background="{StaticResource AccentBrush}">
                            <TextBlock Text="₿" FontSize="36" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="BTC Trading Bot" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="바이낸스 선물 자동매매" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,36"/>

                        <Border Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="24" Margin="0,0,0,24">
                            <StackPanel>
                                <TextBlock Text="시작하기 전에 필요한 것" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                                <!-- 항목 1 -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="22" Height="22" CornerRadius="11" Background="{StaticResource AccentBrush}"
                                            HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <TextBlock Text="1" FontSize="11" Foreground="White" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="바이낸스 계정" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="계정이 없다면 다음 단계에서 가입 안내" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 항목 2 -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="22" Height="22" CornerRadius="11" Background="{StaticResource AccentBrush}"
                                            HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <TextBlock Text="2" FontSize="11" Foreground="White" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="API Key &amp; Secret" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="선물 거래 권한이 활성화된 키" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 항목 3 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="22" Height="22" CornerRadius="11" Background="{StaticResource AccentBrush}"
                                            HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <TextBlock Text="3" FontSize="11" Foreground="White" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="선물 지갑에 USDT" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="최소 50 USDT 이상 권장" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Button Content="시작하기" Command="{Binding NextStepCommand}"
                                Style="{StaticResource PrimaryButton}" Height="44" FontSize="14" Margin="0,0,0,12"/>

                        <TextBlock Text="이미 API 키가 있나요? 바로 입력하기"
                                   FontSize="12" Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" Cursor="Hand"
                                   MouseLeftButtonDown="SkipToInput_Click">
                            <TextBlock.TextDecorations><TextDecorationCollection><TextDecoration/></TextDecorationCollection></TextBlock.TextDecorations>
                        </TextBlock>

                        <!-- 구분선 -->
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="40,20,40,16"/>

                        <TextBlock Text="API 키 없이 체험하기" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <Button Content="테스트 모드로 시작" Command="{Binding StartTestModeCommand}"
                                Style="{StaticResource SecondaryButton}" Height="40" FontSize="13"/>
                    </StackPanel>

                    <!-- ═══ Step 1: Guide ═══ -->
                    <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=1}">

                        <!-- 스텝 인디케이터 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,6,0"/>
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,6,0"/>
                            <Ellipse Width="8" Height="8" Fill="{StaticResource BorderBrush}"/>
                        </StackPanel>

                        <TextBlock Text="API 키 발급 방법" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="바이낸스는 영어 사이트입니다. 아래 노란색 텍스트가 실제 버튼/메뉴 이름입니다." FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,18"/>

                        <!-- Step 1: 선물 계정 활성화 -->
                        <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="1" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Top" Margin="0,2,0,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold" LineHeight="20"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run>선물(Futures) 계정 활성화</Run>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,6,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run>상단 메뉴에서</Run>
                                        <Run FontWeight="Bold" Foreground="#FFFBBF24"> Derivatives </Run>
                                        <Run>→</Run>
                                        <Run FontWeight="Bold" Foreground="#FFFBBF24"> USDS-M Futures </Run>
                                        <Run>클릭</Run>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,4,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run>처음이면</Run>
                                        <Run FontWeight="Bold" Foreground="#FFFBBF24"> Open Now </Run>
                                        <Run>버튼을 눌러 선물 계정을 개설합니다.</Run>
                                    </TextBlock>
                                    <!-- 경고 박스 -->
                                    <Border Background="#33EF4444" CornerRadius="6" Padding="10,8" Margin="0,8,0,0">
                                        <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="16"
                                                   Foreground="{StaticResource DangerBrush}">
                                            <Run FontWeight="Bold">반드시 먼저!</Run>
                                            <Run> Futures 계정 활성화 전에 만든 API 키로는 선물 권한을 켤 수 없습니다. 기존 키가 있다면</Run>
                                            <Run FontWeight="Bold" Foreground="#FFFBBF24"> Delete </Run>
                                            <Run>로 삭제 후, Futures 활성화 완료 뒤에 새 키를 만드세요.</Run>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Step 2: 로그인 후 API Management 이동 -->
                        <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="2" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Top" Margin="0,2,0,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run>우측 상단</Run>
                                        <Run FontWeight="SemiBold">프로필 아이콘</Run><Run> 클릭 →</Run>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,4,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run FontWeight="Bold" Foreground="#FFFBBF24"> Account </Run>
                                        <Run>클릭 → 좌측 메뉴에서</Run>
                                        <Run FontWeight="Bold" Foreground="#FFFBBF24"> API Management </Run>
                                        <Run>클릭</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Step 3: Create API -->
                        <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="3" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Top" Margin="0,2,0,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run FontWeight="Bold" Foreground="#FFFBBF24"> Create API </Run>
                                        <Run>버튼 클릭 → API 타입</Run>
                                        <Run FontWeight="Bold" Foreground="#FFFBBF24"> System generated </Run>
                                        <Run>선택</Run>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,4,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run>API 이름(아무거나) 입력 →</Run>
                                        <Run FontWeight="Bold" Foreground="#FFFBBF24"> Next </Run>
                                        <Run>→ 보안 인증 완료</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Step 4: Edit restrictions - 권한 설정 -->
                        <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="4" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Top" Margin="0,2,0,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run>생성된 API 옆의</Run>
                                        <Run FontWeight="Bold" Foreground="#FFFBBF24"> Edit restrictions </Run>
                                        <Run>클릭:</Run>
                                    </TextBlock>

                                    <!-- Enable Reading -->
                                    <Grid Margin="0,10,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="✓" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Grid.Column="1" FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}">
                                            <Run FontWeight="Bold" Foreground="#FFFBBF24">Enable Reading</Run>
                                            <Run Foreground="{StaticResource TextSecondaryBrush}"> — 읽기 (필수)</Run>
                                        </TextBlock>
                                    </Grid>

                                    <!-- Enable Spot & Margin Trading -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="✓" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Grid.Column="1" FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}">
                                            <Run FontWeight="Bold" Foreground="#FFFBBF24">Enable Spot &amp; Margin Trading</Run>
                                            <Run Foreground="{StaticResource TextSecondaryBrush}"> — 현물 (권장)</Run>
                                        </TextBlock>
                                    </Grid>

                                    <!-- Enable Futures -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="✓" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Grid.Column="1" FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}">
                                            <Run FontWeight="Bold" Foreground="#FFFBBF24">Enable Futures</Run>
                                            <Run Foreground="{StaticResource TextSecondaryBrush}"> — 선물 거래 (필수!)</Run>
                                        </TextBlock>
                                    </Grid>

                                    <!-- Enable Withdrawals - 위험 -->
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="✗" Foreground="{StaticResource DangerBrush}" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Grid.Column="1" FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold">
                                            <Run Foreground="#FFFBBF24">Enable Withdrawals</Run>
                                            <Run> — 절대 체크 금지!</Run>
                                        </TextBlock>
                                    </Grid>

                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Step 5: IP 제한 (필수!) -->
                        <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="5" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Top" Margin="0,2,0,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold" LineHeight="20"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run>IP 제한 설정</Run>
                                        <Run Foreground="{StaticResource DangerBrush}"> (필수!)</Run>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,6,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run>같은 Edit restrictions 페이지에서</Run>
                                        <Run FontWeight="Bold" Foreground="#FFFBBF24"> Restrict access to trusted IPs only </Run>
                                        <Run>를 선택하고 본인 IP를 입력합니다.</Run>
                                    </TextBlock>
                                    <Border Background="#33EF4444" CornerRadius="6" Padding="10,8" Margin="0,8,0,0">
                                        <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="16"
                                                   Foreground="{StaticResource DangerBrush}">
                                            <Run FontWeight="Bold">IP 제한 없이는 Enable Futures를 켤 수 없습니다!</Run>
                                            <Run> 반드시 IP를 등록한 뒤</Run>
                                            <Run FontWeight="Bold" Foreground="#FFFBBF24"> Save </Run>
                                            <Run>를 누르세요.</Run>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Step 6: 키 복사 -->
                        <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="6" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Top" Margin="0,2,0,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <Run FontWeight="SemiBold">API Key</Run><Run>와 </Run>
                                        <Run FontWeight="SemiBold">Secret Key</Run><Run>를 각각</Run>
                                        <Run FontWeight="Bold" Foreground="#FFFBBF24"> Copy </Run>
                                        <Run>버튼으로 복사합니다.</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 경고 -->
                        <Border Background="#22EF4444" CornerRadius="8" Padding="14" Margin="0,0,0,18">
                            <TextBlock FontSize="12" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" LineHeight="18">
                                <Run FontWeight="Bold">주의:</Run>
                                <Run> Secret Key는 생성 직후 1회만 표시됩니다! 반드시 바로 복사해서 안전한 곳에 보관하세요. 페이지를 닫으면 다시 볼 수 없습니다.</Run>
                            </TextBlock>
                        </Border>

                        <!-- 링크 버튼 -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Button Content="바이낸스 가입" Command="{Binding OpenBinanceSignupCommand}"
                                    Style="{StaticResource SecondaryButton}" FontSize="12"/>
                            <Button Grid.Column="2" Content="API Management 열기" Command="{Binding OpenApiManagementCommand}"
                                    Style="{StaticResource SecondaryButton}" FontSize="12"/>
                        </Grid>

                        <!-- 다음 -->
                        <Button Content="API 키 입력하기" Command="{Binding NextStepCommand}"
                                Style="{StaticResource PrimaryButton}" Height="44" FontSize="14"/>
                    </StackPanel>

                    <!-- ═══ Step 2: Input ═══ -->
                    <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=2}">

                        <!-- 스텝 인디케이터 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,6,0"/>
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,6,0"/>
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}"/>
                        </StackPanel>

                        <TextBlock Text="API 키 입력" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="바이낸스에서 발급받은 키를 입력하세요." FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,28"/>

                        <Border Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Label Content="API Key" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,16"/>

                                <Label Content="API Secret" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <PasswordBox x:Name="SecretBox" Margin="0,4,0,12"
                                             PasswordChanged="SecretBox_PasswordChanged"/>

                                <TextBlock Text="로컬에만 저장됩니다. 외부로 전송되지 않습니다."
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Content="{Binding IsTesting, Converter={StaticResource BoolToTestingText}}"
                                Command="{Binding TestConnectionCommand}"
                                IsEnabled="{Binding IsTesting, Converter={StaticResource InverseBool}}"
                                Style="{StaticResource PrimaryButton}" Height="44" FontSize="14" Margin="0,0,0,16"/>

                        <TextBlock Text="{Binding TestStatus}" FontSize="13"
                                   Foreground="{Binding TestStatusColor, Converter={StaticResource StringToBrush}}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding BalanceText}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- ═══ Step 3: Success ═══ -->
                    <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=3}"
                                VerticalAlignment="Center">

                        <Border Width="80" Height="80" CornerRadius="40" Margin="0,40,0,20"
                                HorizontalAlignment="Center" Background="#22C55E">
                            <TextBlock Text="✓" FontSize="40" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="설정 완료!" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding BalanceText}" FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                        <Button Content="거래 시작하기" Command="{Binding CompleteCommand}"
                                Style="{StaticResource SuccessButton}" Height="48" FontSize="15"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
