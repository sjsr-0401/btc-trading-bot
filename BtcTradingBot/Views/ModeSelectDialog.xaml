<Window x:Class="BtcTradingBot.Views.ModeSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BTC Trading Bot — 모드 선택" Height="420" Width="560"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        MouseLeftButtonDown="Window_MouseDown">

    <Border Background="#FF1E1E1E" CornerRadius="12" BorderBrush="#FF333333" BorderThickness="1">
        <Grid Margin="32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                <TextBlock Text="트레이딩 모드 선택" FontSize="20" FontWeight="Bold"
                           Foreground="#FFE4E4E7" HorizontalAlignment="Center"/>
                <TextBlock Text="사용할 트레이딩 모드를 선택하세요" FontSize="12"
                           Foreground="#FF9CA3AF" HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- 모드 카드 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 클래식 모드 -->
                <Border x:Name="ClassicCard" Grid.Column="0" CornerRadius="10" Padding="18,16"
                        Cursor="Hand" MouseLeftButtonDown="Classic_Click"
                        Background="#FF2A2A2A" BorderThickness="2" BorderBrush="#FF333333">
                    <StackPanel>
                        <Border Width="48" Height="48" CornerRadius="24" Background="#333B82F6"
                                HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="K" FontSize="24" FontWeight="Bold" Foreground="#FF3B82F6"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="클래식 모드" FontSize="15" FontWeight="Bold"
                                   Foreground="#FFE4E4E7" HorizontalAlignment="Center"/>
                        <TextBlock Text="KYJ v0.3" FontSize="11" Foreground="#FF3B82F6"
                                   HorizontalAlignment="Center" Margin="0,4,0,8"/>
                        <TextBlock FontSize="11" Foreground="#FF9CA3AF" TextWrapping="Wrap"
                                   TextAlignment="Center" LineHeight="17">
                            <Run>단일 코인 EMA 크로스 전략</Run>
                            <LineBreak/>
                            <Run>스캐너 + 자동 전환</Run>
                            <LineBreak/>
                            <Run>7개 복합지표 분석</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 멀티코인 모드 -->
                <Border x:Name="MultiCard" Grid.Column="2" CornerRadius="10" Padding="18,16"
                        Cursor="Hand" MouseLeftButtonDown="Multi_Click"
                        Background="#FF2A2A2A" BorderThickness="2" BorderBrush="#FF333333">
                    <StackPanel>
                        <Border Width="48" Height="48" CornerRadius="24" Background="#3322C55E"
                                HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="M" FontSize="24" FontWeight="Bold" Foreground="#FF22C55E"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="멀티코인 모드" FontSize="15" FontWeight="Bold"
                                   Foreground="#FFE4E4E7" HorizontalAlignment="Center"/>
                        <TextBlock Text="USDM v1.0" FontSize="11" Foreground="#FF22C55E"
                                   HorizontalAlignment="Center" Margin="0,4,0,8"/>
                        <TextBlock FontSize="11" Foreground="#FF9CA3AF" TextWrapping="Wrap"
                                   TextAlignment="Center" LineHeight="17">
                            <Run>최대 4코인 동시 운용</Run>
                            <LineBreak/>
                            <Run>ADX 레짐 자동 분기</Run>
                            <LineBreak/>
                            <Run>리스크 기반 사이징</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 하단: 앱 종료 -->
            <Grid Grid.Row="4">
                <Button Content="종료" Click="Exit_Click" HorizontalAlignment="Right"
                        Padding="14,6" FontSize="12" Cursor="Hand" Foreground="#FF9CA3AF">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#FF2A2A2A" CornerRadius="6"
                                    BorderBrush="#FF333333" BorderThickness="1"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FF333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
