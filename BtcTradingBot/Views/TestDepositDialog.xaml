<Window x:Class="BtcTradingBot.Views.TestDepositDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="가상 자금 설정" Height="320" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#FF1E1E1E" CornerRadius="12" BorderBrush="#FF333333" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="가상 자금 설정" FontSize="18" FontWeight="Bold" Foreground="#FFE4E4E7"/>
                <TextBlock Text="테스트 모드에서 사용할 가상 잔고를 설정하세요" FontSize="12"
                           Foreground="#FF9CA3AF" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 금액 입력 -->
            <TextBlock Grid.Row="1" Text="가상 잔고 (USDT)" FontSize="12" Foreground="#FF9CA3AF" Margin="0,0,0,4"/>
            <TextBox Grid.Row="2" x:Name="BalanceInput" FontSize="16" Padding="10,8"
                     Background="#FF2A2A2A" Foreground="#FFE4E4E7" BorderBrush="#FF333333"
                     Margin="0,0,0,12"/>

            <!-- 프리셋 버튼 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="$50" Tag="50" Click="Preset_Click" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                <Button Content="$100" Tag="100" Click="Preset_Click" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                <Button Content="$500" Tag="500" Click="Preset_Click" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                <Button Content="$1,000" Tag="1000" Click="Preset_Click" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12"/>
            </StackPanel>

            <!-- 안내 문구 -->
            <TextBlock Grid.Row="4" TextWrapping="Wrap" FontSize="11" Foreground="#FF9CA3AF"
                       Margin="0,0,0,16">
                <Run Text="최소 25 USDT"/>
                <Run Text=" — 레버리지 4x 기준 100 USDT 최소 주문 충족"/>
            </TextBlock>

            <!-- 버튼 -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="취소" Click="Cancel_Click" Style="{StaticResource SecondaryButton}"
                        Padding="16,8" Margin="0,0,8,0"/>
                <Button Content="확인" Click="Confirm_Click" Style="{StaticResource PrimaryButton}"
                        Padding="16,8"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
