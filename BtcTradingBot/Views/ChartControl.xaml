<UserControl x:Class="BtcTradingBot.Views.ChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:views="clr-namespace:BtcTradingBot.Views">

    <UserControl.Resources>
        <views:QtyToWidthConverter x:Key="QtyToWidthConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타임프레임 선택 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="타임프레임" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <ComboBox x:Name="TimeFrameCombo" Width="80" FontSize="12"
                      SelectedValue="{Binding SelectedTimeFrame}" SelectedValuePath="Tag"
                      SelectionChanged="TimeFrame_Changed">
                <ComboBoxItem Content="1분" Tag="1m"/>
                <ComboBoxItem Content="5분" Tag="5m"/>
                <ComboBoxItem Content="15분" Tag="15m" IsSelected="True"/>
                <ComboBoxItem Content="1시간" Tag="1h"/>
                <ComboBoxItem Content="1일" Tag="1D"/>
            </ComboBox>
        </StackPanel>

        <!-- 캔들 + EMA 차트 -->
        <lvc:CartesianChart Grid.Row="1" x:Name="CandleChart"
                            Series="{Binding CandleSeries}"
                            Sections="{Binding Sections}"
                            ZoomMode="None"
                            TooltipPosition="Hidden"/>

        <!-- 볼륨 차트 -->
        <lvc:CartesianChart Grid.Row="2" x:Name="VolumeChart"
                            Series="{Binding VolumeSeries}"
                            ZoomMode="None"
                            TooltipPosition="Hidden"/>

        <!-- 호가 (OrderBook) -->
        <Border Grid.Row="3" Background="{DynamicResource BgCardBrush}"
                CornerRadius="6" Padding="8,6" Margin="0,4,0,0"
                MaxHeight="260">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 매수 (Bids) - 좌측, 초록 -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="매수 (Bid)" FontSize="11" FontWeight="SemiBold"
                               Foreground="#22C55E" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding OrderBookBids}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="20" Margin="0,1">
                                    <!-- 수량 바 (오른쪽 정렬, 초록 배경) -->
                                    <Border HorizontalAlignment="Right" CornerRadius="2"
                                            Background="#2222C55E">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource QtyToWidthConverter}">
                                                <Binding Path="Qty"/>
                                                <Binding Path="DataContext.OrderBookMaxQty"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Path="ActualWidth"
                                                         RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                    <Grid Margin="4,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:N2}'}"
                                                   FontSize="11" Foreground="#22C55E"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Qty, StringFormat='{}{0:N4}'}"
                                                   FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- 매도 (Asks) - 우측, 빨강 -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="매도 (Ask)" FontSize="11" FontWeight="SemiBold"
                               Foreground="#EF4444" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding OrderBookAsks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="20" Margin="0,1">
                                    <!-- 수량 바 (왼쪽 정렬, 빨강 배경) -->
                                    <Border HorizontalAlignment="Left" CornerRadius="2"
                                            Background="#22EF4444">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource QtyToWidthConverter}">
                                                <Binding Path="Qty"/>
                                                <Binding Path="DataContext.OrderBookMaxQty"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Path="ActualWidth"
                                                         RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                    <Grid Margin="4,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:N2}'}"
                                                   FontSize="11" Foreground="#EF4444"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Qty, StringFormat='{}{0:N4}'}"
                                                   FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
