<UserControl x:Class="BtcTradingBot.Views.MultiTradingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BtcTradingBot.ViewModels"
             xmlns:views="clr-namespace:BtcTradingBot.Views">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="260"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- ══ 왼쪽: 포지션 대시보드 + 종목 리스트 ══ -->
        <Border Grid.Column="0" Grid.RowSpan="2" Margin="12,12,6,12"
                Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="포지션" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding EngineState}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 통계 요약 -->
                <Border Grid.Row="1" Background="{DynamicResource BgInputBrush}"
                        CornerRadius="8" Padding="10,8" Margin="0,0,0,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="잔고" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding Balance}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="총 PnL" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{Binding TotalPnl, Converter={StaticResource PnlToColor}}">
                                <Run Text="$"/><Run Text="{Binding TotalPnl, StringFormat=F2, Mode=OneWay}"/>
                            </TextBlock>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="승률" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding WinRate}" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="MDD" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding MaxDrawdown}" FontSize="12"
                                       Foreground="#EF4444"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="수익팩터" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding ProfitFactor}" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 포지션 카드 목록 -->
                <ItemsControl Grid.Row="2" ItemsSource="{Binding PositionCards}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource BgInputBrush}" CornerRadius="8"
                                    Padding="10,8" Margin="0,0,0,6" Cursor="Hand">
                                <StackPanel>
                                    <!-- 헤더: 코인 + 방향 + PnL -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding BaseAsset}" FontWeight="Bold" FontSize="13"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Side}" FontWeight="Bold" FontSize="12" Margin="8,0,0,0"
                                                       Foreground="{Binding SideColor, Converter={StaticResource StringToBrush}}"/>
                                            <TextBlock Text="{Binding LeverageText}" FontSize="10" Margin="6,2,0,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding PnlText}" FontWeight="Bold" FontSize="13"
                                                   Foreground="{Binding PnlColor, Converter={StaticResource StringToBrush}}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- 진입가 | 현재가 -->
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="진입가 (금액)" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding EntryText}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="현재 시장가" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding CurrentText}" FontSize="11" FontWeight="Bold"
                                                       Foreground="{Binding PnlColor, Converter={StaticResource StringToBrush}}"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- SL / TP / 청산 -->
                                    <Grid Margin="0,3,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="SL" FontSize="9" Foreground="#EF4444"/>
                                            <TextBlock Text="{Binding SlText}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="TP" FontSize="9" Foreground="#22C55E"/>
                                            <TextBlock Text="{Binding TpText}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="청산"
                                                Command="{Binding DataContext.ClosePositionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Symbol}"
                                                FontSize="10" FontWeight="Bold" Padding="8,3"
                                                Background="#EF4444" Foreground="White"
                                                BorderThickness="0" Cursor="Hand"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 포지션 없을 때 -->
                <TextBlock Grid.Row="2" Text="포지션 없음" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,20,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PositionCards.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 설정 -->
                <Border Grid.Row="3" Background="{DynamicResource BgInputBrush}"
                        CornerRadius="8" Padding="10,8" Margin="0,6,0,0">
                    <StackPanel>
                        <!-- 테스트 모드 토글 -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="테스트 모드" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Width="40" Height="20" CornerRadius="10"
                                    Cursor="Hand" MouseLeftButtonDown="TestModeToggle_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FF444444"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTestMode}" Value="True">
                                                <Setter Property="Background" Value="#FF22C55E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Ellipse Width="16" Height="16" Fill="White">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="Margin" Value="2,0,0,0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTestMode}" Value="True">
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="Margin" Value="0,0,2,0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </Border>
                        </Grid>

                        <!-- 초기 잔고 (테스트 모드) -->
                        <Grid Margin="0,0,0,6">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTestMode}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                            <TextBlock Text="초기 잔고 ($)" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding TestBalance, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12" Padding="4,2" Background="{DynamicResource BgCardBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="#FF444444"
                                     BorderThickness="1" HorizontalContentAlignment="Right"/>
                        </Grid>

                        <!-- 레버리지 -->
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                            <TextBlock Text="레버리지" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding Leverage, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12" Padding="4,2" Background="{DynamicResource BgCardBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="#FF444444"
                                     BorderThickness="1" HorizontalContentAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 시작/중지 버튼 -->
                <Button Grid.Row="4"
                        Content="{Binding IsRunning, Converter={StaticResource BoolToRunningText}}"
                        Command="{Binding ToggleBotCommand}"
                        Style="{StaticResource SuccessButton}" Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <!-- ══ 중앙: 차트 ══ -->
        <Border Grid.Column="1" Margin="6,12,6,0"
                Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="16">
            <Border.CacheMode><BitmapCache/></Border.CacheMode>
            <views:ChartControl DataContext="{Binding ChartVm}"/>
        </Border>

        <!-- ══ 오른쪽: 선택 종목 리스트 ══ -->
        <Border Grid.Column="2" Grid.RowSpan="2" Margin="6,12,12,12"
                Background="{DynamicResource BgCardBrush}" CornerRadius="10" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="선택 종목" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding SelectedSymbols}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource BgInputBrush}" CornerRadius="6"
                                    Padding="10,6" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding BaseAsset}" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center">
                                            <Run Text="ATR:"/>
                                            <Run Text="{Binding AtrPct, StringFormat=P2, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="10" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0">
                                            <Run Text="{Binding Score, StringFormat=F2, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- ══ 하단: 로그 ══ -->
        <Border Grid.Column="1" Grid.Row="1" Background="{DynamicResource BgCardBrush}"
                Margin="6,6,6,12" CornerRadius="10" Padding="14,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="로그" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         x:Name="MultiLogListBox">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                       Foreground="{Binding Converter={StaticResource LogTextToColor}}"
                                       TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter Margin="0,1"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
