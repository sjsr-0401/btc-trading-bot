<Window x:Class="BtcTradingBot.Views.ThemedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="Height" Width="400" MinHeight="180"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        MouseLeftButtonDown="Window_MouseDown">

    <Border Background="#FF1E1E1E" CornerRadius="12" BorderBrush="#FF333333" BorderThickness="1">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 아이콘 + 메시지 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <Border x:Name="IconCircle" Width="36" Height="36" CornerRadius="18"
                        Background="#FF3B82F6" VerticalAlignment="Top" Margin="0,0,14,0">
                    <TextBlock x:Name="IconText" Text="!" FontSize="20" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center" MaxWidth="270">
                    <TextBlock x:Name="TitleText" FontSize="15" FontWeight="SemiBold"
                               Foreground="#FFE4E4E7"/>
                    <TextBlock x:Name="MessageText" FontSize="12" Foreground="#FF9CA3AF"
                               TextWrapping="Wrap" Margin="0,6,0,0" LineHeight="18"/>
                </StackPanel>
            </StackPanel>

            <!-- 버튼 영역 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <!-- 취소/아니오 버튼 (확인 모드에서만 표시) -->
                <Button x:Name="CancelBtn" Content="아니오" Click="Cancel_Click" Padding="14,8" Margin="0,0,8,0"
                        FontSize="12" Cursor="Hand" Foreground="#FF9CA3AF" Visibility="Collapsed">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#FF2A2A2A" CornerRadius="6"
                                    BorderBrush="#FF333333" BorderThickness="1"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FF333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!-- 확인/예 버튼 -->
                <Button x:Name="OkBtn" Content="확인" Click="Ok_Click" Padding="14,8"
                        FontSize="12" Cursor="Hand" Foreground="White" FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#FF3B82F6" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FF2563EB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
