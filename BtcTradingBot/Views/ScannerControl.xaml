<UserControl x:Class="BtcTradingBot.Views.ScannerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Grid Grid.Row="0" Margin="20,16,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="코인 스캐너" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text=" — KYJ 진입 근접도" FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Bottom" Margin="4,0,0,2"/>
            </StackPanel>
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0"
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                <Run Text="{Binding LastScanTime, Mode=OneWay}"/>
                <Run Text=" | "/>
                <Run Text="{Binding ScanStatus, Mode=OneWay}"/>
            </TextBlock>
            <Button Grid.Column="2" Content="새로고침" Command="{Binding RefreshScanCommand}"
                    IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                    FontSize="12" Padding="14,6" Cursor="Hand"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Background="{DynamicResource BgInputBrush}"
                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"/>
        </Grid>

        <!-- 테이블 헤더 -->
        <Border Grid.Row="1" Margin="20,12,20,0" Background="{DynamicResource BgInputBrush}"
                CornerRadius="6,6,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="#" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="1" Text="코인" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="2" Text="가격" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="3" Text="24h" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="4" Text="준비도" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"
                           ToolTip="진입 점수: 높을수록 EMA 크로스에 가깝거나 신호가 강함 (0-100)"/>
                <TextBlock Grid.Column="5" Text="EMA갭" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"
                           ToolTip="EMA7과 EMA21의 간격 (%). 0%에 가까울수록 크로스 임박"/>
                <TextBlock Grid.Column="6" Text="방향" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="7" Text="RSI" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"
                           ToolTip="RSI 14: 70+ 과매수, 30- 과매도"/>
                <TextBlock Grid.Column="8" Text="ADX" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"
                           ToolTip="ADX: 25+ 강한 추세, 20- 횡보"/>
                <TextBlock Grid.Column="9" Text="거래량" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"
                           ToolTip="24시간 USDT 거래량 (M=백만, B=십억)"/>
                <TextBlock Grid.Column="10" Text="상태" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- 스캔 결과 목록 -->
        <Grid Grid.Row="2" Margin="20,0,20,0">
            <ListBox ItemsSource="{Binding ScanResults}"
                     Background="Transparent" BorderThickness="0"
                     AlternationCount="20"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Padding="12,10"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            Background="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <EventSetter Event="MouseLeftButtonUp" Handler="CoinRow_Click"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <!-- # -->
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Text="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem},
                                              Path=(ItemsControl.AlternationIndex),
                                              Converter={StaticResource IndexPlusOne}}"/>

                            <!-- 코인명 -->
                            <TextBlock Grid.Column="1" Text="{Binding Symbol.BaseAsset}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                            <!-- 가격 -->
                            <TextBlock Grid.Column="2" Text="{Binding PriceText}" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                            <!-- 24h% -->
                            <TextBlock Grid.Column="3" Text="{Binding Change24hText}" FontSize="11"
                                       Foreground="{Binding Change24hColor, Converter={StaticResource StringToBrush}}"
                                       VerticalAlignment="Center"/>

                            <!-- 준비도 바 -->
                            <Grid Grid.Column="4" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Height="8" CornerRadius="4" Background="#22FFFFFF">
                                    <Border CornerRadius="4"
                                            HorizontalAlignment="Left"
                                            Width="{Binding ReadinessScore, Converter={StaticResource ScoreToWidth}}"
                                            Background="{Binding ReadinessColor, Converter={StaticResource StringToBrush}}"/>
                                </Border>
                                <TextBlock Grid.Column="1" FontSize="12" FontWeight="Bold" Margin="8,0,0,0"
                                           Foreground="{Binding ReadinessColor, Converter={StaticResource StringToBrush}}"
                                           Text="{Binding ReadinessScore}"/>
                            </Grid>

                            <!-- EMA갭 -->
                            <StackPanel Grid.Column="5" VerticalAlignment="Center">
                                <TextBlock Text="{Binding EmaGapText}" FontSize="11"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding ConvergenceText}" FontSize="9"
                                           Foreground="#22C55E" Visibility="{Binding EmaGapShrinking, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>

                            <!-- 방향 -->
                            <TextBlock Grid.Column="6" Text="{Binding DirectionText}" FontSize="12" FontWeight="Bold"
                                       Foreground="{Binding DirectionColor, Converter={StaticResource StringToBrush}}"
                                       VerticalAlignment="Center"/>

                            <!-- RSI -->
                            <TextBlock Grid.Column="7" Text="{Binding RsiText}" FontSize="11"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                            <!-- ADX -->
                            <TextBlock Grid.Column="8" Text="{Binding AdxText}" FontSize="11"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                            <!-- 거래량 -->
                            <TextBlock Grid.Column="9" Text="{Binding Volume24hText}" FontSize="11"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                                       ToolTip="{Binding VolumeText, StringFormat='상대 거래량: {0}'}" />

                            <!-- 시장 상태 -->
                            <Border Grid.Column="10" CornerRadius="4" Padding="4,2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                    Background="{DynamicResource BgInputBrush}">
                                <TextBlock Text="{Binding MarketState}" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 결과 없을 때 -->
            <TextBlock Text="스캔 결과가 없습니다. 잠시 후 자동으로 새로고침됩니다."
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ScanResults.Count}" Value="0"/>
                                    <Condition Binding="{Binding IsScanning}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- 스캔 중 오버레이 -->
            <Border Background="#AA000000" CornerRadius="8"
                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="스캔 중..." FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ScanStatus}" FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 하단: 범례 + 안내 -->
        <Border Grid.Row="3" Margin="20,8,20,16" Padding="12,8"
                Background="{DynamicResource BgInputBrush}" CornerRadius="6">
            <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" TextWrapping="Wrap">
                <Run FontWeight="SemiBold">준비도:</Run><Run> 진입점수 (45+ 신호 발생)</Run>
                <Run> | </Run>
                <Run FontWeight="SemiBold">EMA갭:</Run><Run> 0%=크로스임박</Run>
                <Run> | </Run>
                <Run FontWeight="SemiBold">ADX:</Run><Run> 25+=강추세</Run>
                <Run> | </Run>
                <Run FontWeight="SemiBold">RSI:</Run><Run> 70+과매수 30-과매도</Run>
                <Run> | </Run>
                <Run FontWeight="SemiBold">거래량:</Run><Run> 24h USDT (M=백만)</Run>
                <Run> | </Run>
                <Run>코인 클릭 = 트레이딩 이동</Run>
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
