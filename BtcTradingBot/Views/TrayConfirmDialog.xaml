<Window x:Class="BtcTradingBot.Views.TrayConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BTC Trading Bot" Height="200" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        MouseLeftButtonDown="Window_MouseDown">

    <Border Background="#FF1E1E1E" CornerRadius="12" BorderBrush="#FF333333" BorderThickness="1">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 아이콘 + 메시지 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <Border Width="36" Height="36" CornerRadius="18" Background="#FF3B82F6"
                        VerticalAlignment="Top" Margin="0,0,14,0">
                    <TextBlock Text="?" FontSize="20" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center" MaxWidth="270">
                    <TextBlock Text="봇이 실행 중입니다" FontSize="15" FontWeight="SemiBold"
                               Foreground="#FFE4E4E7"/>
                    <TextBlock Text="트레이로 이동하면 봇은 계속 돌아갑니다.&#x0a;트레이로 이동하시겠습니까?"
                               FontSize="12" Foreground="#FF9CA3AF" TextWrapping="Wrap" Margin="0,6,0,0"
                               LineHeight="18"/>
                </StackPanel>
            </StackPanel>

            <!-- 버튼 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="취소" Click="Cancel_Click" Padding="14,8" Margin="0,0,8,0"
                        FontSize="12" Cursor="Hand" Foreground="#FF9CA3AF" Background="Transparent"
                        BorderThickness="1" BorderBrush="#FF333333">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#FF2A2A2A" CornerRadius="6"
                                    BorderBrush="#FF333333" BorderThickness="1"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FF333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="종료" Click="Close_Click" Padding="14,8" Margin="0,0,8,0"
                        FontSize="12" Cursor="Hand" Foreground="White">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#FFEF4444" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FFDC2626"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="트레이로 이동" Click="Tray_Click" Padding="14,8"
                        FontSize="12" Cursor="Hand" Foreground="White" FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#FF3B82F6" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FF2563EB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
